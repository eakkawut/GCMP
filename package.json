{
    "name": "ccmp",
    "publisher": "guokoko",
    "displayName": "AI Chat Models",
    "description": "Provides ZhipuAI, MiniMax, MoonshotAI, DeepSeek, Alibaba Cloud Bailian, Kuaishou Wanqing, Volcengine Ark, Tencent Cloud, Xiaomi MiMo, Baidu Qianfan model support extension for GitHub Copilot Chat, and provides `OpenAI / Anthropic Compatible` custom model support.",
    "version": "0.22.11",
    "license": "MIT",
    "keywords": [
        "ai",
        "chat",
        "copilot",
        "github-copilot",
        "language-model",
        "zhipu",
        "kimi",
        "volcengine",
        "minimax",
        "moonshot",
        "deepseek",
        "streamlake",
        "dashscope",
        "tencent",
        "Xiaomi MiMo",
        "baidu",
        "qianfan",
        "Baidu Qianfan",
        "OpenAI Compatible",
        "Anthropic Compatible",
        "ZhipuAI",
        "Volcengine Ark",
        "MoonshotAI",
        "DeepSeek",
        "Kuaishou Wanqing",
        "Alibaba Cloud Bailian",
        "Tencent Cloud",
        "Baidu Qianfan",
        "Coding Plan Coding Plan"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/VicBilibily/CCMP.git"
    },
    "engines": {
        "vscode": ">=1.116.0",
        "node": ">=20.0.0",
        "npm": ">=9.0.0"
    },
    "extensionDependencies": [
        "github.copilot-chat"
    ],
    "categories": [
        "AI",
        "Chat"
    ],
    "icon": "./ccmp-logo.png",
    "main": "./dist/extension.js",
    "enabledApiProposals": [
        "chatProvider"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onLanguageModelProvider:ccmp.zhipu",
        "onLanguageModelProvider:ccmp.minimax",
        "onLanguageModelProvider:ccmp.moonshot",
        "onLanguageModelProvider:ccmp.deepseek",
        "onLanguageModelProvider:ccmp.dashscope",
        "onLanguageModelProvider:ccmp.streamlake",
        "onLanguageModelProvider:ccmp.volcengine",
        "onLanguageModelProvider:ccmp.tencent",
        "onLanguageModelProvider:ccmp.xiaomimimo",
        "onLanguageModelProvider:ccmp.gemini",
        "onLanguageModelProvider:ccmp.codex",
        "onLanguageModelProvider:ccmp.baidu",
        "onLanguageModelProvider:ccmp.compatible",
        "onLanguageModelTool:ccmp_zhipuWebSearch",
        "onLanguageModelTool:ccmp_minimaxWebSearch",
        "onLanguageModelTool:ccmp_kimiWebSearch",
        "onLanguageModelTool:ccmp_dashscopeWebSearch",
        "onFileSystem:ccmp-settings"
    ],
