            {
                "command": "editor.action.inlineSuggest.trigger",
                "key": "alt+/",
                "when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly && !suggestWidgetVisible"
            },
            {
                "command": "ccmp.nesCompletion.toggleManual",
                "key": "shift+alt+/"
            }
        ],
        "menus": {
            "scm/title": [
                {
                    "command": "ccmp.commit.generateMessage",
                    "group": "navigation",
                    "when": "config.git.enabled && scmProvider == git && ccmp.gitAvailable"
                }
            ],
            "scm/resourceGroup/context": [
                {
                    "command": "ccmp.commit.generateMessageStaged",
                    "when": "config.git.enabled && scmProvider == git && scmResourceGroup == index && ccmp.gitAvailable",
                    "group": "inline@-3"
                },
                {
                    "command": "ccmp.commit.generateMessageWorkingTree",
                    "when": "config.git.enabled && scmProvider == git && scmResourceGroup == workingTree && ccmp.gitAvailable",
                    "group": "inline@-3"
                }
            ]
        }
