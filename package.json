        "languageModelTools": [
            {
                "name": "ccmp_zhipuWebSearch",
                "displayName": "ZhipuAIWeb Search",
                "toolReferenceName": "zhipuWebSearch",
                "modelDescription": "Uses ZhipuAI-provided Web Search functionality to get real-time information. Supports multiple search engines: search_std (Standard search, ¥0.01), search_pro (Advanced search, ¥0.03), search_pro_sogou (Sogou search, ¥0.05), search_pro_quark (Quark search, ¥0.05). Note: Pro+ plans can be called through MCP SSE, non-subscription plans use standard billing interface.",
                "userDescription": "Get latest information through ZhipuAI Web Search",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "search_query": {
                            "type": "string",
                            "description": "Search query string"
                        },
                        "search_engine": {
                            "type": "string",
                            "enum": [
                                "search_std",
                                "search_pro",
                                "search_pro_sogou",
                                "search_pro_quark"
                            ],
                            "description": "Search engine type：search_std（Standard，¥0.01）、search_pro（Advanced，¥0.03）、search_pro_sogou（Sogou，¥0.05）、search_pro_quark（Quark，¥0.05）",
                            "default": "search_std"
                        },
                        "search_intent": {
                            "type": "boolean",
                            "description": "Whether to perform search intent analysis",
                            "default": false
                        },
                        "count": {
                            "type": "integer",
                            "description": "Number of search results to return",
                            "minimum": 1,
                            "maximum": 20,
                            "default": 10
                        },
                        "search_domain_filter": {
                            "type": "string",
                            "description": "Domain filter，Restrict search to specific websites"
                        },
                        "search_recency_filter": {
                            "type": "string",
                            "enum": [
