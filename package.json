        "configuration": {
            "title": "CCMP - AI Chat Models",
            "properties": {
                "ccmp.maxTokens": {
                    "type": "number",
                    "default": 16000,
                    "minimum": 32,
                    "maximum": 256000,
                    "description": "ControlsAIModelmaximum output token count。Larger values allow longer responses。",
                    "scope": "application"
                },
                "ccmp.retry.maxAttempts": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "maximum": 5,
                    "description": "Maximum automatic retry attempts after request failure，Only applies to retryable errors。Retry delay follows 1s、3s、6s、10s、15s increasing sequence。",
                    "scope": "application"
                },
                "ccmp.temperature": {
                    "type": "number",
                    "deprecationMessage": "temperature Deprecated，Please use the model extraBody parameter instead",
                    "description": "Model sampling temperature（Deprecated）",
                    "scope": "application"
                },
                "ccmp.topP": {
                    "type": "number",
                    "deprecationMessage": "topP Deprecated，Please use the model extraBody parameter instead",
                    "description": "Model sampling top-p parameter（Deprecated）",
                    "scope": "application"
                },
                "ccmp.rememberLastModel": {
                    "type": "boolean",
                    "deprecationMessage": "rememberLastModel Deprecated，This feature is no longer supported",
                    "description": "Remember last selected model（Deprecated）",
                    "scope": "application"
                },
                "ccmp.editToolMode": {
                    "type": "string",
                    "enum": [
                        "claude",
                        "gpt-5",
                        "none"
                    ],
                    "enumDescriptions": [
                        "Use Claude-style editing tool (ReplaceString) - Efficient precise single replacement",
                        "Use GPT-5-style editing tool (ApplyPatch) - Batch diff application，Supports complex refactoring",
                        "No specific optimization tool，Direct file editing - Lower efficiency，Suitable for handling edit exceptions"
                    ],
                    "default": "claude",
                    "deprecationMessage": "editToolMode Deprecated，Please use the family field in model configuration instead。This configuration will be removed in future versions。",
                    "description": "Select editing tool mode。Claude Uses efficient ReplaceString，GPT-5 Uses ApplyPatch for batch editing，None Directly uses basic file editing。",
                    "scope": "application"
                },
                "ccmp.autoPrefixModelId": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically add provider prefix to model IDs in model list（e.g., zhipu:::glm-5）。Enabling this option can mitigate VS Code model selector incomplete model display issue。",
                    "scope": "application"
                },
                "ccmp.zhipu.search.enableMCP": {
                    "type": "boolean",
                    "default": true,
                    "description": "EnableZhipuAIsearch MCP SDK mode。Uses standard MCP protocol and official SDK for search functionality，Provides more stable connection and better error handling。Non-subscription plans turn off this switch to use standard billing interface（Pay-per-use）。Requires validZhipuAI API Key。",
                    "scope": "application"
                },
                "ccmp.zhipu.endpoint": {
                    "type": "string",
                    "enum": [
                        "open.bigmodel.cn",
                        "api.z.ai"
                    ],
                    "default": "open.bigmodel.cn",
                    "description": "ZhipuAIAccess site。open.bigmodel.cn is domestic site（Recommended），api.z.ai is international site。",
                    "scope": "application"
                },
                "ccmp.minimax.endpoint": {
                    "type": "string",
                    "enum": [
                        "minimaxi.com",
                        "minimax.io"
                    ],
                    "default": "minimaxi.com",
                    "description": "MiniMax Coding Plan Access site。minimaxi.com is domestic site（Recommended），minimax.io is international site。",
                    "scope": "application"
                },
                "ccmp.xiaomimimo.endpoint": {
                    "type": "string",
                    "enum": [
                        "cn",
                        "sgp",
                        "ams"
                    ],
                    "default": "cn",
                    "description": "Xiaomi MiMo Token Plan Access point。cn is China access point（Default），sgp is Singapore access point，ams is Europe access point。",
                    "scope": "application"
                },
                "ccmp.usages.retentionDays": {
                    "type": "number",
                    "default": 100,
                    "minimum": 0,
                    "maximum": 365,
                    "description": "Token usage record history data retention days（Saved by date，0means permanent retention）。",
                    "scope": "application"
                },
                "ccmp.fimCompletion.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable FIM (Fill In the Middle) Suggestion feature。",
                    "scope": "application"
                },
                "ccmp.fimCompletion.debounceMs": {
                    "type": "number",
                    "default": 500,
                    "minimum": 50,
                    "maximum": 1000,
                    "description": "FIM completion debounce delay（ms）。",
                    "scope": "application"
                },
                "ccmp.fimCompletion.timeoutMs": {
                    "type": "number",
                    "default": 5000,
                    "minimum": 1000,
                    "maximum": 30000,
                    "description": "FIM completion request timeout（ms）。",
                    "scope": "application"
                },
                "ccmp.fimCompletion.modelConfig": {
                    "type": "object",
                    "default": {
                        "provider": "",
                        "baseUrl": "",
                        "model": ""
                    },
                    "description": "FIM completion model configuration。",
                    "scope": "application",
                    "properties": {
                        "provider": {
                            "type": "string",
                            "description": "Model provider identifier"
                        },
                        "baseUrl": {
                            "type": "string",
                            "description": "API base URL",
                            "format": "uri"
                        },
                        "model": {
                            "type": "string",
                            "description": "FIM Completion model name"
                        },
                        "maxTokens": {
                            "type": "number",
                            "description": "FIM Maximum completion return length",
                            "default": 200,
                            "minimum": 50,
                            "maximum": 16000
                        },
                        "extraBody": {
                            "type": "object",
                            "description": "Additional request body parameters，Will be merged into request body in API request",
                            "additionalProperties": {
                                "description": "Additional request body parametersValue"
                            }
                        }
                    },
                    "required": [
                        "provider",
                        "baseUrl",
                        "model"
                    ]
                },
                "ccmp.nesCompletion.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable NES (Next Edit Suggestions) Suggestion feature。",
                    "scope": "application"
                },
                "ccmp.nesCompletion.debounceMs": {
                    "type": "number",
                    "default": 500,
                    "minimum": 50,
                    "maximum": 1000,
                    "description": "NES completion debounce delay（ms）。",
                    "scope": "application"
                },
                "ccmp.nesCompletion.timeoutMs": {
                    "type": "number",
                    "default": 5000,
                    "minimum": 1000,
                    "maximum": 30000,
                    "description": "NES completion request timeout（ms）。",
                    "scope": "application"
                },
                "ccmp.nesCompletion.manualOnly": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enableafter，NES completion only responds to manual trigger（Alt+/），Will not trigger automatically。",
                    "scope": "application"
                },
                "ccmp.nesCompletion.modelConfig": {
                    "type": "object",
                    "default": {
                        "provider": "",
                        "baseUrl": "",
                        "model": ""
                    },
                    "description": "NES completion model configuration。",
                    "scope": "application",
                    "properties": {
                        "provider": {
                            "type": "string",
                            "description": "Model provider identifier"
                        },
                        "baseUrl": {
                            "type": "string",
                            "description": "API base URL",
                            "format": "uri"
                        },
                        "model": {
                            "type": "string",
                            "description": "NES Completion model name"
                        },
                        "maxTokens": {
                            "type": "number",
                            "description": "NES Maximum completion return length",
                            "default": 200,
                            "minimum": 50,
                            "maximum": 16000
                        },
                        "extraBody": {
                            "type": "object",
                            "description": "Additional request body parameters，Will be merged into request body in API request",
                            "additionalProperties": {
                                "description": "Additional request body parametersValue"
                            }
                        }
                    },
                    "required": [
                        "provider",
                        "baseUrl",
                        "model"
                    ]
                },
                "ccmp.commit.language": {
                    "type": "string",
                    "enum": [
                        "chinese",
                        "english"
                    ],
                    "enumDescriptions": [
                        "Chinese - Default/Fallback language（auto when history language is unclear in auto mode, uses Chinese）",
                        "English - Default/fallback language (used when auto mode language is unclear)"
                    ],
                    "default": "chinese",
                    "description": "Language used for generating commit messages。auto Auto mode prioritizes inferring language from recent repository commit history；Falls back to this configuration when history language is unclear。Supports setting in workspace and global configuration，Workspace configuration has higher priority。",
                    "scope": "window"
                },
                "ccmp.commit.format": {
                    "type": "string",
                    "enum": [
                        "auto",
                        "plain",
                        "custom",
                        "conventional",
                        "angular",
                        "karma",
                        "semantic",
                        "emoji",
                        "emojiKarma",
                        "google",
                        "atom"
                    ],
                    "enumDescriptions": [
                        "Auto - Infer commit spec from historical commit records；Falls back to if cannot infer Plain",
                        "Plain - Concise one-line commit description（e.g., fix config fallback logic）",
                        "Custom - Uses custom instructions to generate commit messages（e.g., PROJ-123: fix login redirect）",
                        "Conventional Commits - Conventional commit format（e.g., feat(auth): add login）",
                        "Angular - Angular project style（e.g., fix(core): handle empty config）",
                        "Karma - Karma testing framework style（e.g., feat(ui): add commit wizard）",
                        "Semantic - Semantic version style（e.g., fix: fix invalid format fallback）",
                        "Emoji - Emoji style（e.g., 🐛 fix config fallback）",
                        "EmojiKarma - Emoji + Karma style（e.g., ✨ feat(auth): add login）",
                        "Google - Google project style（e.g., Fix: fix invalid format fallback）",
                        "Atom - Atom editor style（e.g., :bug: fix config fallback）"
                    ],
                    "default": "auto",
                    "description": "Format used for generating commit messages。auto Will infer commit spec from historical commit records；Falls back to if cannot infer plain。Supports setting in workspace and global configuration，Workspace configuration has higher priority。",
                    "scope": "window"
                },
                "ccmp.commit.customInstructions": {
                    "type": "string",
                    "default": "",
                    "description": "Custom commit message generation instructions（When commitFormat=custom takes effect）。",
                    "scope": "window"
                },
                "ccmp.commit.model": {
                    "type": "object",
                    "default": {
                        "provider": "",
                        "model": ""
                    },
                    "description": "Specify model used for generating commit messages（provider + model）。Leaving empty will prompt to select a model。",
                    "scope": "window",
                    "properties": {
                        "provider": {
                            "type": "string",
                            "description": "Language model provider（providerKey），e.g., zhipu / compatible"
                        },
                        "model": {
                            "type": "string",
                            "description": "Model ID（Corresponds to Language Model API model.id）"
                        }
                    },
                    "required": [
                        "provider",
                        "model"
                    ]
                },
                "ccmp.providerOverrides": {
                    "type": "object",
                    "default": {},
                    "description": "Provider configuration override。Allows overriding provider baseUrl and model configuration，Supports adding new models or overriding existing model parameters。",
                    "scope": "application"
                },
                "ccmp.compatibleModels": {
                    "type": "array",
                    "default": [],
                    "description": "Compatible Provider custom model configuration。Fully configured by users OpenAI / Anthropic compatible model list。",
                    "scope": "application"
                }
            }
        },
        "jsonValidation": [
            {
                "fileMatch": "settings.json",
                "url": "ccmp-settings://root/schema.json"
            }
        ],
